# Copy to .env and adjust. Loaded by src/fraud/config.py (pydantic-settings).
# All variables are prefixed with FRAUD_.

# --- data ---
FRAUD_DATA_DIR=./data
FRAUD_PRIMARY_DATASET=ieee-cis        # ieee-cis | credit-card

# --- model / decision policy ---
FRAUD_TARGET_RECALL=0.90              # threshold tuner targets this recall on holdout
FRAUD_MAX_FPR=0.02                    # business constraint: false-positive rate < 2%
FRAUD_REVIEW_BAND=0.15                # score within +/- this of threshold -> "review"

# --- MLflow ---
FRAUD_MLFLOW_TRACKING_URI=http://localhost:5000
FRAUD_MLFLOW_EXPERIMENT=fraud-detection
FRAUD_MODEL_NAME=fraud-stacking-ensemble
FRAUD_MODEL_STAGE=Production          # which registry stage the API serves

# --- serving / logging ---
FRAUD_DATABASE_URL=postgresql+psycopg://fraud:fraud@localhost:5432/fraud
FRAUD_API_PORT=8000

# --- streaming (optional) ---
FRAUD_KAFKA_BOOTSTRAP=localhost:9092
FRAUD_KAFKA_TOPIC=transactions
FRAUD_KAFKA_GROUP=fraud-scorer
